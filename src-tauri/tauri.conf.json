{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Open Grind",
	"version": "0.1.0",
	"identifier": "dev.estopia.free-grind",
	"build": {
		"beforeDevCommand": "bun run dev:web",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "Open Grind",
				"width": 1000,
				"height": 800,
				"userAgent": "OpenGrind/0.1.0 (+https://opengrind.imaoreo.dev/; contact: support@imaoreo.dev)"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {}
	}
}
